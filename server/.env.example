# acolyte/server cors-proxy.py configuration template
# Copy this file to `.env` (which is gitignored) and fill in real values.

# REQUIRED — upstream Ollama URL the proxy forwards /api/* to.
# Use http://localhost:11434 if Ollama runs on the same machine as the proxy.
OLLAMA_UPSTREAM=http://localhost:11434

# OPTIONAL — port the proxy listens on. Default 8767.
LISTEN_PORT=8767

# OPTIONAL — API keys surfaced to the widget via GET /chat-config.
# Leave blank if you don't use that provider; the widget falls back to
# manual settings entry on the user's side.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
